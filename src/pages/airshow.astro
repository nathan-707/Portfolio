---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <main class="container">
    <a href="/" class="back-link">← Back to Portfolio</a>

    <header class="project-header">
      <h1 class="gradient-text">Aircraft Show (visionOS)</h1>
      <p class="subtitle">
        An immersive spatial computing application for Apple Vision Pro, enabling
        users to visualize and interact with high-fidelity 3D aircraft models in
        their physical space.
      </p>
    </header>

    <div class="project-content">
      <div class="detail-section glass animate-fade-in">
        <div class="image-wrapper">
          <img src="/images/airshow_ui.png" alt="Spatial User Interface for Airshow in Augmented Reality" />
        </div>
        <div class="text-content">
          <h2>Immersive Spatial Computing</h2>
          <ul>
            <li>
              Developed a spatial computing application natively for Apple
              Vision Pro using Swift, SwiftUI, and RealityKit.
            </li>
            <li>
              Created intuitive, gaze-based glassmorphism user interfaces for
              users to access detailed aircraft specifications, toggle
              environments, and control animations seamlessly in their physical
              space.
            </li>
          </ul>
        </div>
      </div>

      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.2s"
      >
        <div class="text-content">
          <h2>Realistic Flight Dynamics</h2>
          <ul>
            <li>
              Utilized RealityKit's Entity Component System (ECS) to build
              robust simulations.
            </li>
            <li>
              Implemented realistic flight dynamics and multi-aircraft
              formations directly within the spatial environment.
            </li>
            <li>
              Added interactive altitude and speed controls to manipulate the
              aircraft behavior in real-time.
            </li>
          </ul>
        </div>
        <div class="image-wrapper double-images">
          <img
            src="/images/airshow_formation.png"
            alt="F-35 Fighter Jets Flying in Formation in Augmented Reality"
          />
          <img src="/images/airshow_flight.jpg" alt="F-35 Aircraft Model Displayed in Augmented Reality" />
        </div>
      </div>

      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.4s"
      >
        <div class="image-wrapper">
          <img
            src="/images/airshow_museum.jpg"
            alt="B-2 Spirit Stealth Bomber Showcased in Immersive Virtual Environment"
          />
        </div>
        <div class="text-content">
          <h2>Dynamic Environments</h2>
          <ul>
            <li>
              Implemented fully immersive 3D environments, transporting users to
              realistic landscapes.
            </li>
            <li>
              Leveraged advanced lighting, shadows, and spatial audio to make
              the high-fidelity 3D models of stealth bombers and fighter jets
              feel remarkably real.
            </li>
          </ul>
        </div>
      </div>
    </div>

    <dialog id="image-modal" class="modal">
      <div class="modal-content">
        <span class="close-btn">&times;</span>
        <img id="modal-img" src="" alt="Expanded high-resolution image preview" />
      </div>
    </dialog>
  </main>
  <Footer />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("image-modal");
      const modalImg = document.getElementById("modal-img");
      const closeBtn = document.querySelector(".close-btn");
      const images = document.querySelectorAll(".image-wrapper img");

      images.forEach((img) => {
        img.addEventListener("click", () => {
          modalImg.src = img.src;
          modal.showModal();
        });
      });

      closeBtn.addEventListener("click", () => {
        modal.close();
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.close();
        }
      });
    });
  </script>
</Layout>

<style>
  main {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .project-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .project-header h1 {
    font-size: 3.5rem;
    margin-bottom: 10px;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .detail-section {
    display: flex;
    gap: 40px;
    padding: 40px;
    margin-bottom: 40px;
    align-items: center;
  }

  .detail-section:nth-child(even) {
    flex-direction: row-reverse;
  }

  .image-wrapper {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    max-height: 400px;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .image-wrapper img:hover {
    transform: scale(1.02);
  }

  .double-images {
    display: flex;
    gap: 10px;
    background: transparent !important;
  }

  .double-images img {
    width: calc(50% - 5px);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.2);
  }

  /* Modal Styles */
  .modal {
    border: none;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.95);
    padding: 20px;
    max-width: 90vw;
    max-height: 90vh;
    backdrop-filter: blur(10px);
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
  }

  .modal-content {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .close-btn {
    position: absolute;
    top: -15px;
    right: -10px;
    color: #fff;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: var(--card-bg);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.2s;
  }

  .close-btn:hover {
    background: var(--accent-primary);
  }

  .text-content {
    flex: 1;
  }

  .text-content h2 {
    color: var(--accent-primary);
    margin-bottom: 20px;
    font-size: 1.8rem;
  }

  .text-content ul {
    list-style-type: disc;
    padding-left: 20px;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .text-content li {
    margin-bottom: 15px;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .detail-section,
    .detail-section:nth-child(even) {
      flex-direction: column;
    }
  }
</style>
