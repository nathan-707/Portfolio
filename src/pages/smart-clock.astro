---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <main class="container">
    <a href="/" class="back-link">← Back to Portfolio</a>

    <header class="project-header">
      <h1 class="gradient-text">Internet-Connected Smart Clock</h1>
      <p class="subtitle">
        A comprehensive full-stack IoT device featuring real-time weather
        forecasting, music playback capabilities, and dynamic LED visual
        effects.
      </p>
      <div
        style="margin-top: 30px; display: flex; flex-direction: column; align-items: center; gap: 10px;"
      >
        <a
          href="https://apps.apple.com/us/app/prismbox-connect/id6744375627"
          target="_blank"
          class="app-store-btn"
        >
          View Custom iOS Control App
        </a>
        <span
          style="font-size: 0.9rem; color: var(--text-secondary); max-width: 400px; line-height: 1.4;"
        >
          The custom-built iOS companion app used to remotely control the smart
          clock's lighting, weather location, and settings such as display
          layout.
        </span>
      </div>
    </header>

    <div class="project-content">
      <div class="detail-section glass animate-fade-in">
        <div class="image-wrapper">
          <img
            src={import.meta.env.BASE_URL + "/images/clock_purple.jpg"}
            alt="Fully Assembled Smart Clock Displaying Purple LED Effects"
          />
        </div>
        <div class="text-content">
          <h2>Vibrant LED Effects</h2>
          <ul>
            <li>
              Has dynamic LED lighting that can be customized through the
              companion app.
            </li>
            <li>
              Users can select custom colors, dual gradients, and different
              animated effects.
            </li>
          </ul>
        </div>
      </div>
      <div
        class="detail-section glass animate-fade-in"
      >
        <div class="image-wrapper">
          <img
            src={import.meta.env.BASE_URL + "/images/smart_clock_cad.png"}
            alt="3D CAD Design of the Smart Clock Enclosure"
          />
        </div>
        <div class="text-content">
          <h2>3D Enclosure Design</h2>
          <ul>
            <li>
              Designed a custom 3D-printable enclosure using CAD software like
              Autodesk Fusion 360 to house the custom PCB and dual speakers.
            </li>
            <li>
              Engineered the casing to provide optimal acoustics for music
              playback and a clean display area for the OLED screen.
            </li>
          </ul>
        </div>
      </div>
      <div class="detail-section glass animate-fade-in">
        <div class="image-wrapper">
          <img
            src={import.meta.env.BASE_URL + "/images/smart_clock_pcb.png"}
            alt="Custom Printed Circuit Board Layout for Smart Clock"
          />
        </div>
        <div class="text-content">
          <h2>PCB Layout and Design</h2>
          <ul>
            <li>
              Designed, ordered, and assembled a custom Printed Circuit Board
              (PCB) to handle power distribution, microcontroller interfacing,
              and LED drivers.
            </li>
            <li>
              Ensured precise routing for signal integrity and reliable
              operation of the clock's components.
            </li>
          </ul>
        </div>
      </div>

      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.2s"
      >
        <div class="text-content">
          <h2>Schematic</h2>
          <ul>
            <li>
              Architected the complete electrical schematic integrating an ESP32
              microcontroller.
            </li>
            <li>
              Planned the circuitry to support real-time weather updates, LED
              control, and seamless internet connectivity.
            </li>
          </ul>
        </div>
        <div class="image-wrapper">
          <img
            src={import.meta.env.BASE_URL + "/images/smart_clock_schematic.png"}
            alt="Electrical Schematic Design for Smart Clock"
          />
        </div>
      </div>



      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.6s"
      >
        <div class="text-content">
          <h2>Software & Cloud Integration</h2>
          <ul>
            <li>
              Built a custom iOS app to control the clock remotely, including
              LED visual effects and music playback.
            </li>
            <li>
              Implemented AWS API Gateway for robust cloud services and
              over-the-air (OTA) firmware updates via AWS S3.
            </li>
            <li>
              Created a custom C++ library to directly utilize Apple's
              WeatherKit API on Arduino hardware for live weather forecasting.
            </li>
          </ul>
        </div>
        <div class="image-wrapper double-images">
          <img
            src={import.meta.env.BASE_URL + "/images/app_home.png"}
            alt="iOS Companion App Home Screen Interface"
          />
          <img
            src={import.meta.env.BASE_URL + "/images/app_settings.png"}
            alt="iOS Companion App Settings and Configuration Interface"
          />
        </div>
      </div>


    </div>

    <dialog id="image-modal" class="modal">
      <div class="modal-content">
        <span class="close-btn">&times;</span>
        <img
          id="modal-img"
          src=""
          alt="Expanded high-resolution image preview"
        />
      </div>
    </dialog>
  </main>
  <Footer />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("image-modal");
      const modalImg = document.getElementById("modal-img");
      const closeBtn = document.querySelector(".close-btn");
      const images = document.querySelectorAll(".image-wrapper img");

      images.forEach((img) => {
        img.addEventListener("click", () => {
          modalImg.src = img.src;
          modal.showModal();
        });
      });

      closeBtn.addEventListener("click", () => {
        modal.close();
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.close();
        }
      });
    });
  </script>
</Layout>

<style>
  main {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .project-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .project-header h1 {
    font-size: 3.5rem;
    margin-bottom: 10px;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
  }

  .app-store-btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: 600;
    background: var(--accent-glow);
    border: 1px solid var(--accent-primary);
    color: #fff;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .app-store-btn:hover {
    background: var(--accent-primary);
    box-shadow: 0 10px 20px var(--accent-glow);
    transform: translateY(-2px);
  }

  .detail-section {
    display: flex;
    gap: 40px;
    padding: 40px;
    margin-bottom: 40px;
    align-items: center;
  }

  .detail-section:nth-child(even) {
    flex-direction: row-reverse;
  }

  .image-wrapper {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    max-height: 400px;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .image-wrapper img:hover {
    transform: scale(1.02);
  }

  /* Modal Styles */
  .modal {
    border: none;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.95);
    padding: 20px;
    max-width: 90vw;
    max-height: 90vh;
    backdrop-filter: blur(10px);
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
  }

  .modal-content {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .close-btn {
    position: absolute;
    top: -15px;
    right: -10px;
    color: #fff;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: var(--card-bg);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.2s;
  }

  .close-btn:hover {
    background: var(--accent-primary);
  }

  .text-content {
    flex: 1;
  }

  .text-content h2 {
    color: var(--accent-primary);
    margin-bottom: 20px;
    font-size: 1.8rem;
  }

  .text-content ul {
    list-style-type: disc;
    padding-left: 20px;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .text-content li {
    margin-bottom: 15px;
    font-size: 1.1rem;
  }

  .double-images {
    display: flex;
    gap: 10px;
    background: transparent !important;
  }

  .double-images img {
    width: calc(50% - 5px);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .detail-section,
    .detail-section:nth-child(even) {
      flex-direction: column;
    }
  }
</style>
