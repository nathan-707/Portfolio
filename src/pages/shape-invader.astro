---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <main class="container">
    <a href="/" class="back-link">← Back to Portfolio</a>

    <header class="project-header">
      <h1 class="gradient-text">Shape Invader (visionOS)</h1>
      <p class="subtitle">
        An immersive spatial AR/VR game utilizing RealityKit, SwiftUI, and advanced spatial
        audio for Apple Vision Pro.
      </p>
    </header>

    <div class="project-content">
      <div class="detail-section glass animate-fade-in">
        <div class="image-wrapper">
          <img
            src="/images/shape_invader_gameplay_ar.png"
            alt="Shape Invader Augmented Reality Gameplay Interface"
          />
        </div>
        <div class="text-content">
          <h2>Spatial AR/VR Gameplay</h2>
          <ul>
            <li>
              Designed a spatial computing game specifically for Apple Vision
              Pro.
            </li>
            <li>
              Successfully launched alongside the device's release as one of the
              first 600 apps available globally on the App Store.
            </li>
            <li>
              Developed dynamic 3D gameplay using RealityKit's physics engine
              for accurate collision detection and interactive particle
              emitters.
            </li>
          </ul>
        </div>
      </div>

      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.2s"
      >
        <div class="text-content">
          <h2>Immersive Environments</h2>
          <ul>
            <li>
              Implemented diverse spatial environments seamlessly blending
              digital content with the real world.
            </li>
            <li>
              Players can seamlessly transition between fully immersive VR space
              scenes and AR pass-through modes depending on their preference.
            </li>
          </ul>
        </div>
        <div class="image-wrapper">
          <img
            src="/images/shape_invader_gameplay_vr.png"
            alt="Shape Invader Virtual Reality Gameplay in Space Environment"
          />
        </div>
      </div>

      <div
        class="detail-section glass animate-fade-in"
        style="animation-delay: 0.4s"
      >
        <div class="image-wrapper double-images">
          <img
            src="/images/shape_invader_menu_ar.png"
            alt="Shape Invader Main Menu in Augmented Reality"
          />
          <img
            src="/images/shape_invader_gameover_vr.png"
            alt="Shape Invader Game Over Screen in Virtual Reality"
          />
        </div>
        <div class="text-content">
          <h2>Spatial UI & Game States</h2>
          <ul>
            <li>
              Utilized SwiftUI to craft intuitive spatial interfaces that float
              seamlessly in the user's environment.
            </li>
            <li>
              Engineered a dynamic UI system that adapts to various game states
              (Main Menu, Gameplay, Game Over) and visually aligns with the
              chosen AR or VR environment.
            </li>
          </ul>
        </div>
      </div>
    </div>

    <dialog id="image-modal" class="modal">
      <div class="modal-content">
        <span class="close-btn">&times;</span>
        <img id="modal-img" src="" alt="Expanded high-resolution image preview" />
      </div>
    </dialog>
  </main>
  <Footer />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("image-modal");
      const modalImg = document.getElementById("modal-img");
      const closeBtn = document.querySelector(".close-btn");
      const images = document.querySelectorAll(".image-wrapper img");

      images.forEach((img) => {
        img.addEventListener("click", () => {
          modalImg.src = img.src;
          modal.showModal();
        });
      });

      closeBtn.addEventListener("click", () => {
        modal.close();
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.close();
        }
      });
    });
  </script>
</Layout>

<style>
  main {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .project-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .project-header h1 {
    font-size: 3.5rem;
    margin-bottom: 10px;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .detail-section {
    display: flex;
    gap: 40px;
    padding: 40px;
    margin-bottom: 40px;
    align-items: center;
  }

  .detail-section:nth-child(even) {
    flex-direction: row-reverse;
  }

  .image-wrapper {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    max-height: 400px;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .image-wrapper img:hover {
    transform: scale(1.02);
  }

  .double-images {
    display: flex;
    gap: 10px;
    background: transparent !important;
  }

  .double-images img {
    width: calc(50% - 5px);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.2);
  }

  /* Modal Styles */
  .modal {
    border: none;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.95);
    padding: 20px;
    max-width: 90vw;
    max-height: 90vh;
    backdrop-filter: blur(10px);
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
  }

  .modal-content {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .close-btn {
    position: absolute;
    top: -15px;
    right: -10px;
    color: #fff;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: var(--card-bg);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.2s;
  }

  .close-btn:hover {
    background: var(--accent-primary);
  }

  .text-content {
    flex: 1;
  }

  .text-content h2 {
    color: var(--accent-primary);
    margin-bottom: 20px;
    font-size: 1.8rem;
  }

  .text-content ul {
    list-style-type: disc;
    padding-left: 20px;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .text-content li {
    margin-bottom: 15px;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .detail-section,
    .detail-section:nth-child(even) {
      flex-direction: column;
    }
  }
</style>
