---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main class="container">
    <a href="/" class="back-link">← Back to Portfolio</a>
    
    <header class="project-header">
      <h1 class="gradient-text">Commonwealth Family Chiropractic App</h1>
      <p class="subtitle">A comprehensive native iOS application empowering a local clinic with seamless online appointment scheduling, patient reviews, and streamlined communication.</p>
      <div style="margin-top: 30px;">
        <a href="https://apps.apple.com/us/app/commonwealth-fmly-chiropractic/id6446209042" target="_blank" class="app-store-btn">
          View on App Store
        </a>
      </div>
    </header>

    <div class="project-content">
      <div class="detail-section glass animate-fade-in">
        <div class="image-wrapper double-images">
          <img src="/images/chiro_about_top.png" alt="About Us Interface of the Chiropractic iOS Application" />
          <img src="/images/chiro_about_bottom.png" alt="Clinic Services Interface of the Chiropractic iOS Application" />
        </div>
        <div class="text-content">
          <h2>Custom User Interface</h2>
          <ul>
            <li>Designed and developed a fully native iOS application from scratch using Swift and Storyboards.</li>
            <li>Created a custom, user-friendly interface to enhance patient engagement and provide quick access to clinic information, locations, and services.</li>
          </ul>
        </div>
      </div>

      <div class="detail-section glass animate-fade-in" style="animation-delay: 0.2s">
        <div class="text-content">
          <h2>Online Scheduling & Engagement</h2>
          <ul>
            <li>Integrated seamless online appointment scheduling for multiple clinic locations (Elizabethtown and Hodgenville).</li>
            <li>Enabled patients to easily leave reviews and access essential clinic details on the go.</li>
            <li>Successfully launched on the App Store, where it maintains a 5-star rating and is utilized daily by patients.</li>
          </ul>
        </div>
        <div class="image-wrapper">
          <img src="/images/chiro_appointments.png" alt="Online Appointment Scheduling Interface of the Chiropractic iOS Application" style="max-width: 300px; margin: 0 auto; display: block;" />
        </div>
      </div>
    </div>

    <dialog id="image-modal" class="modal">
      <div class="modal-content">
        <span class="close-btn">&times;</span>
        <img id="modal-img" src="" alt="Expanded high-resolution image preview" />
      </div>
    </dialog>
  </main>
  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('image-modal');
      const modalImg = document.getElementById('modal-img');
      const closeBtn = document.querySelector('.close-btn');
      const images = document.querySelectorAll('.image-wrapper img');

      images.forEach(img => {
        img.addEventListener('click', () => {
          modalImg.src = img.src;
          modal.showModal();
        });
      });

      closeBtn.addEventListener('click', () => {
        modal.close();
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.close();
        }
      });
    });
  </script>
</Layout>

<style>
  main {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .project-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .project-header h1 {
    font-size: 3.5rem;
    margin-bottom: 10px;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .app-store-btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: 600;
    background: var(--accent-glow);
    border: 1px solid var(--accent-primary);
    color: #fff;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .app-store-btn:hover {
    background: var(--accent-primary);
    box-shadow: 0 10px 20px var(--accent-glow);
    transform: translateY(-2px);
  }

  .detail-section {
    display: flex;
    gap: 40px;
    padding: 40px;
    margin-bottom: 40px;
    align-items: center;
  }

  .detail-section:nth-child(even) {
    flex-direction: row-reverse;
  }

  .image-wrapper {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0,0,0,0.2);
    padding: 20px;
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    max-height: 500px;
    cursor: zoom-in;
    transition: transform 0.3s ease;
    border-radius: 8px;
  }

  .image-wrapper img:hover {
    transform: scale(1.02);
  }

  .double-images {
    display: flex;
    gap: 20px;
    background: transparent !important;
  }

  .double-images img {
    width: calc(50% - 10px);
    border-radius: 8px;
    background: transparent;
  }

  /* Modal Styles */
  .modal {
    border: none;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.95);
    padding: 20px;
    max-width: 90vw;
    max-height: 90vh;
    backdrop-filter: blur(10px);
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(5px);
  }

  .modal-content {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .modal-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .close-btn {
    position: absolute;
    top: -15px;
    right: -10px;
    color: #fff;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: var(--card-bg);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.2s;
  }

  .close-btn:hover {
    background: var(--accent-primary);
  }

  .text-content {
    flex: 1;
  }

  .text-content h2 {
    color: var(--accent-primary);
    margin-bottom: 20px;
    font-size: 1.8rem;
  }

  .text-content ul {
    list-style-type: disc;
    padding-left: 20px;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .text-content li {
    margin-bottom: 15px;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .detail-section, .detail-section:nth-child(even) {
      flex-direction: column;
    }
  }
</style>
