];
---

<section id="projects" class="section container">
  <h2 class="section-title">Featured Projects</h2>

  <div class="timeline-wrapper">
    {timelineYears.map((yearGroup) => (
      <div class="year-group">
        <div class="year-marker">
          <div class="year-line"></div>
          <span class="year-badge gradient-text">{yearGroup.year}</span>
          <div class="year-line"></div>
        </div>
        <div class="projects-list">
          {yearGroup.projects.map((project) => (
            <div class="project-accordion glass" data-id={project.id}>
              <!-- Card Header (always visible) -->
              <div class="accordion-header" role="button" tabindex="0" aria-expanded="false">
                <div
                  class="accordion-thumb"
                  style={project.image
                    ? `background-image: url('${BASE}${project.image}')`
                    : `background: ${project.backgroundColor}`}
                >
                </div>
                <div class="accordion-meta">
                  <span class="platform">{project.platform}</span>
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>
                  {project.appStoreUrl && (
                    <a href={project.appStoreUrl} target="_blank" class="app-store-btn" onclick="event.stopPropagation()">
                      {project.appStoreLabel}
                    </a>
                  )}
                </div>
                <div class="accordion-toggle">
                  <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
              </div>

              <!-- Expandable Case Study Content -->
              <div class="accordion-body">
                <div class="case-study-inner">
                  {project.sections.map((section, i) => (
                    <div class={`detail-section ${i % 2 === 0 ? '' : 'reverse'}`}>
                      <div class="text-content">
                        <h4>{section.heading}</h4>
                        <ul>
                          {section.text.map((point) => <li>{point}</li>)}
                        </ul>
                      </div>
                      <div class="image-content">
                        {section.doubleImages ? (
                          <div class="double-images">
                            <img src={BASE + section.doubleImages[0]} alt={section.doubleAlts[0]} class="zoomable" />
                            <img src={BASE + section.doubleImages[1]} alt={section.doubleAlts[1]} class="zoomable" />
                          </div>
                        ) : (
                          <img src={BASE + section.image} alt={section.imageAlt} class="single-image zoomable" />
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Shared image zoom modal -->
<dialog id="proj-modal" class="proj-modal">
  <div class="proj-modal-content">
    <span class="proj-close-btn">&times;</span>
    <img id="proj-modal-img" src="" alt="Full size preview" />
  </div>
</dialog>

<script>
  // Accordion toggle
  document.querySelectorAll('.accordion-header').forEach((header) => {
    const toggle = () => {
      const accordion = header.closest('.project-accordion') as HTMLElement;
      const body = accordion.querySelector('.accordion-body') as HTMLElement;
      const isOpen = accordion.classList.contains('open');

      if (isOpen) {
        body.style.maxHeight = body.scrollHeight + 'px';
        requestAnimationFrame(() => {
          body.style.maxHeight = '0';
        });
        accordion.classList.remove('open');
        header.setAttribute('aria-expanded', 'false');
      } else {
        accordion.classList.add('open');
        header.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        body.addEventListener('transitionend', () => {
          if (accordion.classList.contains('open')) {
            body.style.maxHeight = 'none';
          }
        }, { once: true });
      }
    };

    header.addEventListener('click', toggle);
    header.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  // Image zoom modal
  const modal = document.getElementById('proj-modal') as HTMLDialogElement;
  const modalImg = document.getElementById('proj-modal-img') as HTMLImageElement;
  const closeBtn = document.querySelector('.proj-close-btn');

  document.querySelectorAll('.zoomable').forEach((img) => {
    img.addEventListener('click', () => {
      modalImg.src = (img as HTMLImageElement).src;
      modal.showModal();
    });
  });

  closeBtn?.addEventListener('click', () => modal.close());
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
</script>

<style>
  /* Timeline wrapper */
  .timeline-wrapper {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .year-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Year divider */
  .year-marker {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }

  .year-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  }

  .year-badge {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 2px;
    white-space: nowrap;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Accordion card */
  .project-accordion {
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .project-accordion.open {
    border-color: var(--accent-primary);
    box-shadow: 0 0 30px rgba(63,185,80,0.15);
  }

  /* Header row */
  .accordion-header {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 20px 24px;
    cursor: pointer;
    user-select: none;
    transition: background 0.2s;
  }
  .accordion-header:hover { background: rgba(255,255,255,0.03); }

  .accordion-thumb {
    width: 120px;
    height: 80px;
    border-radius: 10px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .accordion-meta {
    flex: 1;
    min-width: 0;
  }
  .accordion-meta h3 {
    font-size: 1.3rem;
    margin: 4px 0 8px;
  }
  .accordion-meta p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .platform {
    font-size: 0.78rem;
    color: var(--accent-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    display: block;
  }

  .accordion-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    color: var(--accent-primary);
  }
  .chevron {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
  }
  .project-accordion.open .chevron {
    transform: rotate(180deg);
  }

  /* App store button inside card */
  .app-store-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 7px 16px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.82rem;
    background: var(--accent-glow);
    border: 1px solid var(--accent-primary);
    color: #fff;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .app-store-btn:hover {
    background: var(--accent-primary);
    transform: translateY(-1px);
  }

  /* Accordion body */
  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .case-study-inner {
    padding: 0 24px 30px;
    border-top: 1px solid var(--border-color);
    margin-top: 0;
  }

  /* Detail sections inside accordion */
  .detail-section {
    display: flex;
    gap: 40px;
    padding: 36px 0;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .detail-section:last-child { border-bottom: none; }
  .detail-section.reverse { flex-direction: row-reverse; }

  .text-content { flex: 1; }
  .text-content h4 {
    color: var(--accent-primary);
    margin-bottom: 16px;
    font-size: 1.4rem;
  }
  .text-content ul {
    list-style-type: disc;
    padding-left: 20px;
    color: var(--text-primary);
    line-height: 1.6;
  }
  .text-content li {
    margin-bottom: 12px;
    font-size: 1rem;
  }

  .image-content { flex: 1; }

  .single-image {
    width: 100%;
    height: auto;
    max-height: 380px;
    object-fit: contain;
    border-radius: 10px;
    background: rgba(0,0,0,0.2);
    display: block;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }
  .single-image:hover { transform: scale(1.02); }

  .double-images {
    display: flex;
    gap: 12px;
  }
  .double-images img {
    width: calc(50% - 6px);
    height: auto;
    max-height: 380px;
    object-fit: contain;
    border-radius: 10px;
    background: rgba(0,0,0,0.2);
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }
  .double-images img:hover { transform: scale(1.02); }

  /* Modal */
  .proj-modal {
    border: none;
    border-radius: 12px;
    background: rgba(13, 17, 23, 0.97);
    padding: 20px;
    max-width: 90vw;
    max-height: 90vh;
    backdrop-filter: blur(10px);
  }
  .proj-modal::backdrop {
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(5px);
  }
  .proj-modal-content {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .proj-modal-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }
  .proj-close-btn {
    position: absolute;
    top: -15px;
    right: -10px;
    color: #fff;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: var(--card-bg);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.2s;
  }
  .proj-close-btn:hover { background: var(--accent-primary); }

  @media (max-width: 768px) {
    .accordion-thumb { width: 80px; height: 60px; }
    .detail-section, .detail-section.reverse { flex-direction: column; }
    .double-images { flex-direction: column; }
    .double-images img { width: 100%; }
    .accordion-header { gap: 14px; padding: 16px; }
    .year-badge { font-size: 1.5rem; }
  }
</style>
