<section id="about" class="hero-section container">
  <div class="hero-content">
    <h1 class="animate-fade-in">
      Hi, I'm <span class="gradient-text">Nathan Eriksen</span>
    </h1>
    <h2 class="role animate-fade-in" style="animation-delay: 0.2s">
      Software Engineer · iOS &amp; Embedded Systems
    </h2>

    <p class="bio animate-fade-in" style="animation-delay: 0.4s">
      I build native iOS applications, spatial computing experiences for Apple
      Vision Pro, and full-stack embedded systems with custom hardware. Currently
      pursuing a B.S. in Computer Science at the University of Louisville's J.B.
      Speed School of Engineering.
    </p>

    <div class="social-links animate-fade-in" style="animation-delay: 0.6s">
      <a href="https://github.com/nathan-707" target="_blank" class="glass-btn">
        GitHub
      </a>
      <a href="mailto:nperik01@louisville.edu" class="glass-btn primary">
        Contact Me
      </a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
  }

  .hero-content {
    max-width: 800px;
  }

  h1 {
    font-size: 4.5rem;
    font-weight: 800;
    margin-bottom: 10px;
    line-height: 1.1;
  }

  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--accent-primary),
      var(--accent-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .role {
    font-size: 1.8rem;
    color: var(--text-secondary);
    font-weight: 400;
    margin-bottom: 30px;
  }

  .bio {
    font-size: 1.2rem;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .social-links {
    display: flex;
    gap: 20px;
    justify-content: center;
  }

  .glass-btn {
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: 600;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    color: #fff;
  }

  .glass-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .glass-btn.primary {
    background: var(--accent-glow);
    border-color: var(--accent-primary);
  }

  .glass-btn.primary:hover {
    background: var(--accent-primary);
    box-shadow: 0 10px 20px var(--accent-glow);
  }
</style>
