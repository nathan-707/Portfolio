<style>
  .navbar {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 800px;
    z-index: 1000;
    padding: 15px 30px;
    border-radius: 50px;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 800;
    font-size: 1.5rem;
    color: #fff;
    letter-spacing: 1px;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 30px;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 1rem;
  }

  .nav-links a:hover {
    color: var(--accent-primary);
  }
</style>
