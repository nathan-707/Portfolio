---
const experiences = [
  {
    title: "Web Development Intern",
    company: "RedTag Digital",
    location: "Louisville, KY",
    date: "June 2025 - August 2025",
    description: [
      "Developed and maintained client and internal websites utilizing HTML, CSS, JavaScript, and SQL within an agile team environment.",
      "Worked on a team to design and maintain websites for clients and internal use.",
      "Orchestrated the 'Brewtal Portfolio' Review for RedTag.",
      "Published Landing Page: www.redtag.digital/brewtal-review"
    ]
  },
  {
    title: "Freelance iOS Developer",
    company: "CommonwealthFamilyChiro",
    location: "Remote",
    date: "2023 - Present",
    description: [
      "Developed and deployed a custom iOS application for a local chiropractic practice.",
      "Integrated scheduling functionality to streamline patient booking and improve client communication.",
      "Published App on the App Store. <a href='/chiro-app' style='color: var(--accent-primary); text-decoration: underline; font-weight: 500;'>View Case Study &rarr;</a>"
    ]
  }
];
---
<section id="experience" class="section container">
  <h2 class="section-title">Experience</h2>
  
  <div class="timeline">
    {experiences.map((exp, index) => (
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content glass">
          <div class="timeline-header">
            <h3>{exp.title}</h3>
            <span class="date">{exp.date}</span>
          </div>
          <h4 class="company">{exp.company} <span class="location">| {exp.location}</span></h4>
          <ul class="task-list">
            {exp.description.map((item) => (
              <li set:html={item}></li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border-color);
  }

  .timeline-item {
    position: relative;
    padding-left: 60px;
    margin-bottom: 40px;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: 14px;
    top: 24px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 2px solid var(--accent-primary);
    z-index: 2;
    transition: background-color 0.3s ease;
  }

  .timeline-item:hover .timeline-dot {
    background: var(--accent-primary);
    box-shadow: 0 0 10px var(--accent-glow);
  }

  .timeline-content {
    padding: 30px;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 5px;
    flex-wrap: wrap;
    gap: 10px;
  }

  h3 {
    margin: 0;
    font-size: 1.3rem;
  }

  .date {
    color: var(--accent-secondary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .company {
    margin: 0 0 15px 0;
    color: var(--text-primary);
    font-size: 1.1rem;
    font-weight: 500;
  }

  .location {
    color: var(--text-secondary);
    font-weight: 400;
  }

  .task-list {
    margin: 0;
    padding-left: 20px;
    color: var(--text-secondary);
  }

  .task-list li {
    margin-bottom: 8px;
    line-height: 1.5;
  }
</style>
