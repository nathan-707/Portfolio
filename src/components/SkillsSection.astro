---
const skills = [
  {
    category: "Languages",
    items: ["Swift", "C++", "Python", "JavaScript", "SQL", "HTML/CSS"],
  },
  {
    category: "Frameworks & Platforms",
    items: [
      "SwiftUI",
      "RealityKit",
      "ARKit",
      "AccessorySetupKit",
    ],
  },
  {
    category: "Cloud & Infrastructure",
    items: ["AWS S3", "AWS API Gateway", "IoT Architecture", "Git/GitHub"],
  },
  {
    category: "Hardware & CAD",
    items: [
      "PCB Layout & Design",
      "Microcontroller Programming (ESP32)",
      "3D Printing & Additive Manufacturing",
      "Autodesk Fusion 360",
      "Autodesk EAGLE",
      "Autodesk Inventor",
    ],
  },
];
---

<section id="skills" class="section container">
  <h2 class="section-title">Skills & Technologies</h2>

  <div class="skills-grid">
    {
      skills.map((skillGroup) => (
        <div class="skill-card glass">
          <h3>{skillGroup.category}</h3>
          <div class="skill-pills">
            {skillGroup.items.map((skill) => (
              <span class="pill">{skill}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .skill-card {
    padding: 25px;
    transition: transform 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-5px);
  }

  h3 {
    margin-bottom: 20px;
    font-size: 1.2rem;
    color: var(--accent-secondary);
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pill {
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    font-size: 0.9rem;
    color: var(--text-primary);
    transition: all 0.2s ease;
  }

  .skill-card:hover .pill {
    border-color: var(--accent-glow);
    background: rgba(63, 185, 80, 0.1);
  }
</style>
